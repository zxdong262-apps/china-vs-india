//- Data Table Section
section#data-table.section(aria-labelledby='data-table-title')
  h2#data-table-title.section-title
    span= locale.dataTable.dataTable
    - var buttonId = 'downloadTableBtnTop'
    - var btnClass = 'download-btn-top'
    include download-button
  .table-container
    table.data-table#table(role='table', aria-describedby='table-desc')
      caption.sr-only#table-desc Statistical comparison data between China and the rest of the world
      thead
        tr
          th#tableUrl.table-header-url(colspan=7, scope='colgroup')
            .url-qr-container
              if isProduction
                - var qrCodeName = currentLocale === 'en_US' ? 'qrcode-china-vs-india.png' : 'qrcode-china-vs-india-' + currentLocale + '.png'
                img.qr-code(src='/images/' + qrCodeName, alt='QR Code')
              else
                #qr-code-wrap
                  img.qr-code#qrcode-dev(alt='QR Code')
              span.url-text
        tr
          th(scope='col')= locale.dataTable.category || 'Category'
          th(scope='col')= locale.regions.china
          th(colspan=2, scope='colgroup')= locale.regions.china + ' %'
          th(scope='col')= locale.regions.restOfWorld
          th(scope='col')= locale.regions.world
          th(scope='col')= locale.dataTable.year || 'Year'
      tbody
        each item in dataItems
          - const itemData = getDataByPath(data, item.path);
          - const itemLabel = locale.data[item.key];
          - const chinaPercent = Math.round(itemData.china / (itemData.china + itemData.india) * 100);
          - const indiaPercent = 100 - chinaPercent;
          tr
            th(scope='row').category
              span #{item.icon} #{itemLabel}
              span.unit-label  (#{locale.units[itemData.unit] || itemData.unit})
            td.china
              - const chinaValue = itemData.china
              - const chinaGDP = itemData.militaryBudgetInGDP ? itemData.militaryBudgetInGDP.china + '% GDP' : ''
              - const chinaFiscalRevenue = itemData.militaryBudgetInFiscalRevenue ? itemData.militaryBudgetInFiscalRevenue.china + '% ' + locale.data.fiscalRevenue : ''
              - const chinaSuffix = chinaGDP && chinaFiscalRevenue ? '(' + chinaGDP + ', ' + chinaFiscalRevenue + ')' : (chinaGDP ? '(' + chinaGDP + ')' : (chinaFiscalRevenue ? '(' + chinaFiscalRevenue + ')' : ''))
              span.value= chinaValue + chinaSuffix
            td(colspan=2)
              .percent-bar-container
                .percent-bar.china-bar(style='width:' + chinaPercent + '%')
                .percent-bar.india-bar(style='width:' + indiaPercent + '%')
            td
              - const indiaValue = itemData.india
              - const indiaGDP = itemData.militaryBudgetInGDP ? itemData.militaryBudgetInGDP.india + '% GDP' : ''
              - const indiaFiscalRevenue = itemData.militaryBudgetInFiscalRevenue ? itemData.militaryBudgetInFiscalRevenue.india + '% ' + locale.data.fiscalRevenue : ''
              - const indiaSuffix = indiaGDP && indiaFiscalRevenue ? '(' + indiaGDP + ', ' + indiaFiscalRevenue + ')' : (indiaGDP ? '(' + indiaGDP + ')' : (indiaFiscalRevenue ? '(' + indiaFiscalRevenue + ')' : ''))
              span.value= indiaValue + indiaSuffix
            td
              span.value= itemData.world
            td= itemData.year
  .download-section
    - var buttonId = 'downloadTableBtn'
    include download-button